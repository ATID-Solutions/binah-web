---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/binah/Nav.astro";
import Footer from "../components/binah/Footer.astro";
import CtaBand from "../components/binah/CtaBand.astro";
import { ALL_SEO_FEATURE_PAGES, FEATURED_SOLUTIONS } from "../lib/marketing-pages";
import { waUrl, WA_MESSAGES } from "../components/binah/whatsapp";

const grouped = {
  P0: ALL_SEO_FEATURE_PAGES.filter((page) => page.priority === "P0"),
  P1: ALL_SEO_FEATURE_PAGES.filter((page) => page.priority === "P1"),
  P2: ALL_SEO_FEATURE_PAGES.filter((page) => page.priority === "P2"),
};

const solutionGroups = [
  { priority: "P0", label: "Páginas de captura principal", pages: grouped.P0 },
  { priority: "P1", label: "Long-tail de alto valor", pages: grouped.P1 },
  { priority: "P2", label: "Nichos y casos específicos", pages: grouped.P2 },
] as const;
---

<Layout
  title="Soluciones para negocios colombianos — Binah"
  description="Páginas de solución de Binah para CRM, remarketing, EAN/GTIN, facturación DIAN, ventas, despachos, pagos, inventario, agentes IA y operación en Colombia."
  page="soluciones"
  canonicalPath="/soluciones"
>
  <Nav />
  <main>
    <div class="container-binah">
      <div class="crumb">
        <a href="/">Binah</a> <span class="sep">/</span> Soluciones
      </div>

      <section class="binah-section no-border" style="padding: 40px 0 56px;">
        <div class="eyebrow">Soluciones / Colombia</div>
        <h1 class="display display-lg" style="margin-top: 20px; max-width: 15ch;">
          Problemas concretos. Páginas concretas.
        </h1>
        <p class="lead" style="margin-top: 28px; font-size: 18px;">
          Cada página explica un flujo que una empresa colombiana puede necesitar resolver: códigos EAN,
          facturación DIAN, CRM por WhatsApp, remarketing, despachos, pagos, inventario y más.
        </p>
        <div class="hero-cta">
          <a href={waUrl(WA_MESSAGES.demo)} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            Agendar demo <span class="arrow">→</span>
          </a>
          <a href="/modulos" class="btn btn-outline">Ver módulos</a>
        </div>
      </section>

      <section class="binah-section">
        <div class="section-num">
          <span class="n">P0</span><span>Prioridad alta</span><span class="rule"></span><span>{FEATURED_SOLUTIONS.length} páginas</span>
        </div>
        <div class="solution-index-hero">
          {
            FEATURED_SOLUTIONS.map((page) => (
              <a href={page.path}>
                <span class="mono">{page.priority}</span>
                <h2>{page.h1}</h2>
                <p>{page.colombiaUseCase}</p>
                <strong>Ver página →</strong>
              </a>
            ))
          }
        </div>
      </section>

      <section class="binah-section">
        <div class="section-head">
          <h2 class="display display-md title">Todas las soluciones.</h2>
          <p>
            Publicadas como rutas reales, enlazadas desde el sitio y listas para entrar al sitemap.
          </p>
        </div>

        {
          solutionGroups.map((group) => (
            <div class="solution-group">
              <div class="solution-group-head">
                <span class="mono">{group.priority}</span>
                <p>{group.label}</p>
              </div>
              <div class="solution-link-list">
                {group.pages.map((page) => (
                  <a href={page.path}>
                    <span>{page.title.replace(" — Binah", "")}</span>
                    <small>{page.moduleName}</small>
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </section>

      <CtaBand
        eyebrow="Soluciones Binah"
        heading="Convierte búsqueda<br />en conversación."
        body="Cada página apunta a un problema real y termina en una demo con contexto del negocio."
        primaryHref={waUrl(WA_MESSAGES.demo)}
        secondaryLabel="Ver precios"
        secondaryHref="/precios"
      />
    </div>
  </main>
  <Footer />
</Layout>

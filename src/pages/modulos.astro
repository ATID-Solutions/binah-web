---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/binah/Nav.astro";
import Footer from "../components/binah/Footer.astro";
import ModuleList from "../components/binah/ModuleList.tsx";
import { FEATURED_SOLUTIONS } from "../lib/marketing-pages";
---

<Layout
  title="Módulos — Binah"
  description="Explora los módulos de Binah: CRM, soporte, ventas, facturación electrónica, contabilidad, operaciones, tareas y más herramientas conectadas en una sola base de datos."
  page="modulos"
  canonicalPath="/modulos"
>
  <Nav />
  <main>
    <div class="container-binah">
      <div class="crumb">
        <a href="/">Binah</a> <span class="sep">/</span> Módulos
      </div>

      <section class="binah-section no-border" style="padding: 40px 0 56px;">
        <div class="eyebrow">Catálogo / 10 módulos</div>
        <h1 class="display display-lg" style="margin-top: 20px; max-width: 16ch;">
          Toma solo los que necesitas. O todos.
        </h1>
        <p class="lead" style="margin-top: 28px; font-size: 18px;">
          Cada módulo funciona independiente. Pero cuando los activas todos, Binah se convierte en el único sistema que tu negocio necesita.
        </p>
      </section>

      <section class="binah-section no-border" style="padding: 0 0 96px;">
        <ModuleList client:load />
      </section>

      <section class="binah-section">
        <div class="section-head">
          <h2 class="display display-md title">Soluciones por problema.</h2>
          <p>
            Los módulos son la estructura. Estas páginas explican búsquedas concretas de operación, ventas, pagos, DIAN e inventario en Colombia.
          </p>
        </div>
        <div class="related-links-grid">
          {
            FEATURED_SOLUTIONS.map((page) => (
              <a href={page.path}>
                <span>{page.title.replace(" — Binah", "")}</span>
                <strong>→</strong>
              </a>
            ))
          }
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

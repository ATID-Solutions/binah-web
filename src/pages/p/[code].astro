---
import PublicPolicyPage from "../../components/public-policy/PublicPolicyPage.astro";
import PublicPolicyLayout from "../../layouts/PublicPolicyLayout.astro";
import {
  buildPublicPolicyPageState,
  getPublicPolicyPageTitle,
} from "../../lib/publicPolicy";

export const prerender = false;

const { code } = Astro.params;
const pageState = await buildPublicPolicyPageState({
  actionsBaseUrl: import.meta.env.ACTIONS_BASE_URL,
  code,
});

Astro.response.status = pageState.status;
Astro.response.headers.set("X-Robots-Tag", "noindex, nofollow");

const pageTitle = getPublicPolicyPageTitle(pageState);
---

<PublicPolicyLayout title={pageTitle}>
  <PublicPolicyPage pageState={pageState} />
</PublicPolicyLayout>

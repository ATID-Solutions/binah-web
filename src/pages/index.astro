---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/binah/Nav.astro";
import Footer from "../components/binah/Footer.astro";
import CtaBand from "../components/binah/CtaBand.astro";
import HeroLogos from "../components/binah/HeroLogos.tsx";
import GoogleReviews from "../components/binah/GoogleReviews.astro";
import ModuleGrid from "../components/binah/ModuleGrid.tsx";
import OperationalSavingsBanner from "../components/binah/OperationalSavingsBanner.tsx";
import { waUrl, WA_MESSAGES } from "../components/binah/whatsapp";
import { FEATURED_SOLUTIONS } from "../lib/marketing-pages";

const heroDemoHref = waUrl(WA_MESSAGES.demo);
const featuredSolutionCopy: Record<string, { kicker: string; title: string; body: string }> = {
  "codigos-ean-productos-colombia": {
    kicker: "EAN / GTIN",
    title: "Códigos que sí cuadran",
    body: "Productos, variantes y códigos listos para vender en marketplaces, tienda física y bodega.",
  },
  "facturacion-electronica-dian": {
    kicker: "DIAN",
    title: "Factura sin copiar datos",
    body: "La venta termina en factura electrónica y conciliación sin abrir otra operación manual.",
  },
  "crm-whatsapp-instagram-colombia": {
    kicker: "CRM",
    title: "Inbox para vender y atender",
    body: "WhatsApp, Instagram y email con historial, asesores, estados y seguimiento.",
  },
  "agente-ia-ventas-whatsapp": {
    kicker: "IA",
    title: "Respuestas con contexto",
    body: "Automatiza preguntas repetidas, recopila datos y escala solo lo que necesita una persona.",
  },
  "software-despachos-transportadoras-colombia": {
    kicker: "Despachos",
    title: "Guías, rótulos y tracking",
    body: "Pedidos conectados a transportadoras, novedades y avisos al cliente desde el mismo flujo.",
  },
  "links-de-pago-whatsapp-colombia": {
    kicker: "Pagos",
    title: "Cobros desde la conversación",
    body: "Envía links de pago, confirma recaudo y mantiene el pedido actualizado en tiempo real.",
  },
};
const featuredSolutionCards = FEATURED_SOLUTIONS.map((page) => ({
  href: page.path,
  ...(featuredSolutionCopy[page.slug] ?? {
    kicker: page.moduleName,
    title: page.title.replace(" — Binah", ""),
    body: page.lead,
  }),
}));
---

<Layout
  title="Binah — El sistema operativo de los negocios colombianos"
  description="Binah reúne CRM, soporte, ventas, facturación electrónica DIAN, contabilidad, operaciones y agentes IA en una sola plataforma para negocios colombianos."
  page="index"
  canonicalPath="/"
>
  <Nav />

  <main>
    <div class="container-binah">
      <section class="binah-section hero no-border">
        <div class="eyebrow">Binah / v. 2026</div>
        <h1 class="display display-xl" style="margin-top: 24px;">
          Vende más.<br />
          <em>Opera mejor.</em><br />
          1 plataforma.
        </h1>
        <p class="hero-sub">
          CRM, soporte, ventas, facturación electrónica, contabilidad, operaciones, tareas y más — diez módulos que trabajan como uno. Deja de pagar por ocho herramientas. Corre tu negocio en una sola.
        </p>
        <div style="margin-top: 32px;">
          <HeroLogos client:load />
        </div>
        <div class="hero-cta">
          <a href={heroDemoHref} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            Agendar demo <span class="arrow">→</span>
          </a>
          <a href="/modulos" class="btn btn-outline">Ver módulos</a>
        </div>
        <div class="hero-meta">
          <span><span class="dot"></span>Facturación electrónica DIAN</span>
          <span><span class="dot"></span>WhatsApp Business API</span>
          <span><span class="dot"></span>Equipos desde 1 hasta 500+</span>
        </div>

      </section>
    </div>

    <div class="container-binah">
      <section class="binah-section">
        <div class="section-num">
          <span class="n">01</span><span>Módulos</span><span class="rule"></span><span>10 en 1</span>
        </div>
        <div class="section-head">
          <h2 class="display display-lg title">
            Diez módulos.<br />
            Una sola base de datos.
          </h2>
          <p>
            Cada módulo es útil por sí solo. Juntos son imbatibles: una venta cerrada en el CRM puede disparar la factura electrónica, reservar inventario, generar despacho, abrir un ticket de soporte y avisar al equipo por chat interno. Todo conectado.
          </p>
        </div>
        <ModuleGrid client:load />
      </section>

      <OperationalSavingsBanner client:load />

      <section class="binah-section">
        <div class="section-num">
          <span class="n">03</span><span>Datos en vivo</span><span class="rule"></span><span>Sin Excel</span>
        </div>
        <div class="solution-statement">
          <h2 class="display display-md">
            Preguntas que deberían responderse sin pedir un reporte.
          </h2>
          <p>
            Binah convierte la operación diaria en datos disponibles: ventas, asesores, productos, bodegas, atención al cliente
            y trazabilidad de cada acción.
          </p>
        </div>
        <div class="editorial-list" style="margin-top: 40px;">
          <div class="editorial-row">
            <span class="mono">WhatsApp</span>
            <p>¿Cuánto se demora cada asesor en responder y qué conversaciones terminan en venta?</p>
          </div>
          <div class="editorial-row">
            <span class="mono">Ventas</span>
            <p>¿Cuántos pedidos cierra cada asesor, por canal, producto y periodo?</p>
          </div>
          <div class="editorial-row">
            <span class="mono">Soporte</span>
            <p>¿Qué tickets están abiertos, quién responde, cuánto falta para el SLA y qué motivos se repiten?</p>
          </div>
          <div class="editorial-row">
            <span class="mono">Bodegas</span>
            <p>¿Qué bodega vende, separa o despacha más, y dónde se queda represado el flujo?</p>
          </div>
          <div class="editorial-row">
            <span class="mono">Productos</span>
            <p>¿Qué productos se mueven mejor, cuáles se quedan quietos y cómo impactan inventario?</p>
          </div>
          <div class="editorial-row">
            <span class="mono">Auditoría</span>
            <p>Cada acción queda registrada: lo que hizo el sistema, lo que hizo cada usuario y lo que pasó con cada pedido.</p>
          </div>
        </div>
      </section>

      <section class="binah-section">
        <div class="section-num">
          <span class="n">04</span><span>Remarketing</span><span class="rule"></span><span>Clientes antiguos</span>
        </div>
        <div class="solution-statement">
          <h2 class="display display-md">
            La plataforma colombiana que también piensa en el remarketing.
          </h2>
          <p>
            ¿Qué pasa con tus clientes antiguos? Binah los conserva con historial, segmentos y campañas para que la recompra no dependa de memoria ni Excel.
          </p>
        </div>
        <div class="editorial-list" style="margin-top: 40px;">
          <div class="editorial-row">
            <span class="mono">01</span>
            <p>Ventas reactiva clientes que ya compraron, sin perder el contexto de la conversación original.</p>
          </div>
          <div class="editorial-row">
            <span class="mono">02</span>
            <p>Logística, contador, analista, asesor, gerente, atención al cliente y soporte trabajan sobre la misma verdad.</p>
          </div>
          <div class="editorial-row">
            <span class="mono">03</span>
            <p>Las campañas dejan de ser envíos masivos sueltos y se convierten en seguimiento medible de recompra.</p>
          </div>
        </div>
        <div style="margin-top: 28px;">
          <a href="/remarketing-clientes-antiguos-whatsapp-colombia" class="btn btn-outline">Ver remarketing</a>
        </div>
      </section>

      <section class="binah-section home-solutions-section">
        <div class="home-solutions-strip" aria-label="Soluciones Binah">
          {
            featuredSolutionCards.map((solution, index) => (
              <a href={solution.href} class="home-solution-card">
                <span class="home-solution-meta">
                  <span class="mono">{String(index + 1).padStart(2, "0")}</span>
                  <span>{solution.kicker}</span>
                </span>
                <strong>{solution.title}</strong>
                <p>{solution.body}</p>
                <span class="home-solution-action">
                  Ver solución <span aria-hidden="true">→</span>
                </span>
              </a>
            ))
          }
        </div>
      </section>
    </div>

    <div class="container-binah home-after-solutions">
      <GoogleReviews />

      <CtaBand
        id="demo"
        eyebrow="Empieza hoy"
        heading={`Una demo.<br />Cero compromisos.<br />Todas las respuestas.`}
        body="Agenda 30 minutos con nuestro equipo. Te mostramos cómo luciría Binah corriendo tu negocio específicamente."
        primaryLabel="Agendar demo"
        primaryHref={waUrl(WA_MESSAGES.demo)}
        secondaryLabel="Ver precios"
        secondaryHref="/precios"
      />
    </div>
  </main>

  <Footer />
</Layout>

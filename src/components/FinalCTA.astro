---
import BrutalistButton from "./ui/BrutalistButton.astro";
---

<section
  id="cta"
  class="py-24 lg:py-32 relative overflow-hidden border-y border-slate-200/60"
>
  <!-- Immersive Background Glows -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-[1000px] h-[600px] bg-gradient-to-r from-binah-cyan/20 via-binah-purple/20 to-binah-pink/20 opacity-30 blur-[150px] rounded-full pointer-events-none z-0"
  >
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
    <h2
      class="text-5xl sm:text-6xl lg:text-8xl font-extrabold tracking-tighter text-slate-900 leading-[0.95] mb-8"
    >
      Lleva tu <span class="whitespace-nowrap">e-commerce</span><br />
      <span
        class="text-transparent bg-clip-text bg-gradient-to-r from-binah-cyan via-binah-purple to-binah-pink"
        >al siguiente nivel</span
      >
    </h2>
    <p class="text-xl text-slate-600 font-medium max-w-2xl mx-auto mb-12">
      Únete a los negocios colombianos que ya automatizan su operación con
      Binah. Empieza tu prueba gratis hoy.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <BrutalistButton
        variant="primary"
        size="lg"
        href="https://app.binah.co/onboarding"
      >
        Comenzar Gratis
      </BrutalistButton>
      <BrutalistButton variant="secondary" size="lg" href="#">
        Agendar Demo
      </BrutalistButton>
    </div>
    <p class="mt-8 text-slate-500 text-sm font-medium">
      Sin tarjeta de crédito. 14 días de prueba gratis. Cancela cuando quieras.
    </p>
  </div>
</section>

---
import BrutalistButton from "./ui/BrutalistButton.astro";
import BrowserMockup from "./BrowserMockup.astro";
---

<section
  class="relative pt-32 pb-8 overflow-hidden min-h-[90vh] flex flex-col justify-center"
>
  <!-- Glowing subtle gradients behind the content -->
  <div
    class="absolute top-[-10%] left-[-10%] w-[600px] h-[600px] rounded-full bg-binah-purple opacity-10 blur-[150px]"
  >
  </div>
  <div
    class="absolute bottom-[-10%] right-[-10%] w-[500px] h-[500px] rounded-full bg-binah-cyan opacity-10 blur-[150px]"
  >
  </div>
  <div
    class="absolute top-[30%] left-[60%] w-[400px] h-[400px] rounded-full bg-binah-pink opacity-[0.08] blur-[120px]"
  >
  </div>

  <div
    class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex-1 flex items-center"
  >
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center w-full">
      <!-- Left column -->
      <div class="flex flex-col gap-8">
        <h1
          class="text-5xl sm:text-6xl lg:text-8xl font-extrabold text-slate-900 tracking-tighter leading-[1.1]"
        >
          Tu negocio.<br />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-binah-cyan via-binah-purple to-binah-pink"
            >Una</span
          > plataforma.
        </h1>

        <p
          class="text-slate-600 text-lg sm:text-xl font-medium max-w-lg leading-relaxed"
        >
          Pedidos, seguimiento de clientes, envíos, facturación, inventario y
          WhatsApp con IA — desde un solo lugar.
        </p>

        <div class="flex flex-wrap gap-4 mt-2">
          <BrutalistButton
            variant="primary"
            size="lg"
            href="https://app.binah.co/onboarding"
          >
            Comenzar Gratis
          </BrutalistButton>
          <BrutalistButton variant="secondary" size="lg" href="#como-funciona">
            Ver Cómo Funciona
          </BrutalistButton>
        </div>

        <div
          class="flex items-center gap-6 mt-6 text-slate-500 text-sm font-medium"
        >
          <span class="flex items-center gap-2">
            <svg
              class="w-5 h-5 text-binah-cyan"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"></path>
            </svg>
            Sin tarjeta de crédito
          </span>
          <span class="flex items-center gap-2">
            <svg
              class="w-5 h-5 text-binah-pink"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"></path>
            </svg>
            14 días prueba gratis
          </span>
        </div>
      </div>

      <!-- Right column -->
      <div class="flex justify-center lg:justify-start">
        <BrowserMockup />
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="flex justify-center pb-4 pt-6">
    <a
      href="#integraciones"
      class="scroll-indicator flex flex-col items-center gap-1.5 text-slate-400 hover:text-slate-600 transition-colors"
    >
      <span class="text-xs font-bold tracking-widest uppercase">Scroll</span>
      <svg
        class="w-5 h-5 animate-bounce"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </a>
  </div>
</section>

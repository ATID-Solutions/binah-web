---
const testimonials = [
  {
    name: "Carolina Restrepo",
    role: "Fundadora, BellaNatura.co",
    quote:
      "Antes tardaba 3 horas al día gestionando envíos y facturas. Con Binah todo se genera automático cuando despacho. Ahora me enfoco en hacer crecer mi marca.",
    rating: 5,
  },
  {
    name: "Andrés Mejía",
    role: "Director Comercial, TechStore",
    quote:
      "El chatbot de WhatsApp nos cambió el juego. Atiende el 70% de consultas solo y cuando detecta una venta, crea el pedido directamente en la plataforma.",
    rating: 5,
  },
  {
    name: "Valentina Gómez",
    role: "Gerente de Operaciones, ModaCo",
    quote:
      "Conectamos Shopify en 10 minutos. Los pedidos caen directo, se generan guías de Coordinadora y se factura en Siigo. Cero copiar y pegar.",
    rating: 5,
  },
];

const StarIcon = `<svg class="w-5 h-5 text-binah-cyan drop-shadow-[0_0_8px_rgba(0,209,255,0.8)]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>`;
---

<section
  id="testimonios"
  class="bg-transparent py-24 lg:py-32 relative overflow-hidden"
>
  <!-- Subtle Background elements -->
  <div
    class="absolute top-0 right-0 w-[400px] h-[400px] bg-binah-purple opacity-5 blur-[120px] rounded-full pointer-events-none"
  >
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-20 lg:mb-28">
      <h2
        class="text-4xl lg:text-5xl font-extrabold tracking-tighter text-slate-900"
      >
        Lo que dicen <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-binah-purple to-binah-pink"
          >nuestros clientes</span
        >
      </h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        testimonials.map((testimonial) => (
          <div class="bg-white border border-slate-200 rounded-[32px] p-8 lg:p-10 flex flex-col relative overflow-hidden group hover:-translate-y-2 transition-transform duration-500 hover:border-slate-300 shadow-sm hover:shadow-xl">
            <div class="absolute inset-0 bg-gradient-to-br from-slate-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" />

            <div class="flex gap-1.5 mb-8 relative z-10">
              {Array.from({ length: testimonial.rating }).map(() => (
                <Fragment set:html={StarIcon} />
              ))}
            </div>
            <blockquote class="text-slate-600 font-medium leading-relaxed flex-1 mb-8 text-lg relative z-10">
              "{testimonial.quote}"
            </blockquote>
            <div class="flex items-center gap-4 pt-6 border-t border-slate-100 relative z-10">
              <div class="w-12 h-12 bg-slate-50 border border-slate-200 rounded-full flex items-center justify-center text-slate-700 font-extrabold text-sm backdrop-blur-sm">
                {testimonial.name
                  .split(" ")
                  .map((n) => n[0])
                  .join("")}
              </div>
              <div>
                <div class="font-bold text-slate-900 tracking-tight">
                  {testimonial.name}
                </div>
                <div class="text-sm text-slate-500 font-medium">
                  {testimonial.role}
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

---
const personas = [
  {
    badge: 'E-commerce',
    badgeColor: 'text-binah-cyan bg-binah-cyan/10 border-binah-cyan/20',
    bg: 'bg-white hover:bg-slate-50',
    borderColor: 'border-slate-200 hover:border-binah-cyan/30',
    textColor: 'text-slate-900',
    descColor: 'text-slate-600',
    glow: 'shadow-sm hover:shadow-md',
    title: 'Vende en línea sin perder el control',
    description:
      'Conecta Shopify o WooCommerce y centraliza pedidos, envíos, inventario y facturación. Tu tienda online operando en piloto automático.',
    stats: [
      { value: '100%', label: 'Pedidos centralizados' },
      { value: '3x', label: 'Más rápido despachar' },
    ],
  },
  {
    badge: 'Servicios',
    badgeColor: 'text-binah-purple bg-binah-purple/10 border-binah-purple/20',
    bg: 'bg-gradient-to-br from-[#1A1A1A] to-[#111111]',
    borderColor: 'border-binah-purple/30',
    textColor: 'text-white',
    descColor: 'text-slate-300',
    glow: 'shadow-[0_0_40px_rgba(77,55,246,0.1)] hover:shadow-[0_0_50px_rgba(77,55,246,0.2)]',
    title: 'Gestiona citas, cotizaciones y seguimientos',
    description:
      'Agenda actividades, recoge evidencias en campo, genera cotizaciones y convierte en pedidos. Todo vinculado al cliente.',
    stats: [
      { value: '5x', label: 'Menos tiempo admin' },
      { value: '360°', label: 'Vista del cliente' },
    ],
  },
  {
    badge: 'Logística',
    badgeColor: 'text-binah-pink bg-binah-pink/10 border-binah-pink/20',
    bg: 'bg-white hover:bg-slate-50',
    borderColor: 'border-slate-200 hover:border-binah-pink/30',
    textColor: 'text-slate-900',
    descColor: 'text-slate-600',
    glow: 'shadow-sm hover:shadow-md',
    title: 'Despacha a nivel nacional',
    description:
      'Genera guías con Coordinadora, Envía, TCC, Inter Rapidísimo, Servientrega y más. Centraliza tus transportadoras en un solo lugar.',
    stats: [
      { value: '2+', label: 'Transportadoras' },
      { value: '99.9%', label: 'Uptime' },
    ],
  },
];
---

<section class="py-24 lg:py-32 border-b border-slate-200/60 relative overflow-hidden">
  <!-- Subtle background glow -->
  <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-binah-cyan opacity-[0.05] blur-[100px] rounded-full pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-20 lg:mb-28">
      <h2 class="text-4xl lg:text-5xl font-extrabold tracking-tighter text-slate-900">
        Hecho para <span class="text-transparent bg-clip-text bg-gradient-to-r from-binah-purple to-binah-pink">tu tipo de negocio</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        personas.map((persona) => (
          <div
            class={`${persona.bg} ${persona.borderColor} border rounded-[32px] p-8 lg:p-10 flex flex-col group transition-all duration-500 hover:-translate-y-2 ${persona.glow} relative overflow-hidden`}
          >
            <!-- Hover gradient effect (only visible on dark card) -->
            <div class={persona.bg.includes('white') ? "hidden" : "absolute inset-0 bg-gradient-to-t from-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"}></div>
            
            <span class={`inline-flex self-start text-xs font-bold px-3 py-1.5 rounded-full border mb-8 backdrop-blur-sm ${persona.badgeColor} relative z-10 transition-colors duration-300`}>
              {persona.badge}
            </span>
            <h3
              class={`text-2xl font-extrabold tracking-tight ${persona.textColor} mb-4 relative z-10`}
            >
              {persona.title}
            </h3>
            <p class={`${persona.descColor} font-medium leading-relaxed mb-8 flex-1 text-lg relative z-10`}>
              {persona.description}
            </p>
            <div class={`flex gap-8 pt-6 border-t ${persona.bg.includes('white') ? 'border-slate-200' : 'border-white/10'} relative z-10`}>
              {
                persona.stats.map((stat) => (
                  <div>
                    <div class={`text-3xl font-extrabold ${persona.textColor} tracking-tight`}>{stat.value}</div>
                    <div class={`text-sm font-medium ${persona.descColor} mt-1`}>{stat.label}</div>
                  </div>
                ))
              }
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

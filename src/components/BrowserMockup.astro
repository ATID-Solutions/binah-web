<div
  class="bg-[#0A0A0A] border border-white/10 rounded-[24px] shadow-2xl overflow-hidden w-full lg:w-[150%] lg:max-w-none mockup-root relative lg:-mr-[15vw]"
  id="dashboard-mockup"
>
  <!-- Background glow for the mockup itself -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-binah-purple/5 to-transparent pointer-events-none"
  >
  </div>

  <!-- Browser chrome -->
  <div
    class="bg-black/80 backdrop-blur-md px-4 py-3 flex items-center gap-2 border-b border-white/5 relative z-10"
  >
    <div class="w-3 h-3 rounded-full bg-[#ff5f57]/80"></div>
    <div class="w-3 h-3 rounded-full bg-[#febc2e]/80"></div>
    <div class="w-3 h-3 rounded-full bg-[#28c840]/80"></div>
    <div
      class="ml-4 flex-1 bg-white/5 border border-white/10 rounded-md h-6 flex items-center px-3"
    >
      <span class="text-[10px] text-white/40 font-mono tracking-wide"
        >app.binah.co/dashboard</span
      >
    </div>
    <!-- Live indicator -->
    <div class="flex items-center gap-1.5 ml-2">
      <div
        class="w-2 h-2 rounded-full bg-binah-cyan shadow-[0_0_8px_rgba(0,209,255,0.8)] live-dot"
      >
      </div>
      <span class="text-[9px] text-white/50 font-bold tracking-widest"
        >LIVE</span
      >
    </div>
  </div>

  <!-- Dashboard content -->
  <div class="relative z-10 p-4 grid grid-cols-3 gap-3">
    <!-- Ventas card -->
    <div
      class="col-span-2 bg-[#111111] border border-white/5 rounded-[24px] p-4 relative overflow-hidden group"
    >
      <div
        class="absolute inset-0 bg-gradient-to-br from-binah-purple/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
      >
      </div>
      <div class="text-xs font-semibold text-white/50 mb-1">Ventas del mes</div>
      <div class="text-2xl font-extrabold text-white">
        $<span class="counter" data-target="12480000" data-format="currency"
          >0</span
        >
      </div>
      <div class="mt-4 flex items-end gap-[2px] h-16">
        <div
          class="w-full bg-white/5 rounded-t-sm bar-animate"
          data-height="40"
        >
        </div>
        <div
          class="w-full bg-white/10 rounded-t-sm bar-animate"
          data-height="55"
        >
        </div>
        <div
          class="w-full bg-white/10 rounded-t-sm bar-animate"
          data-height="35"
        >
        </div>
        <div
          class="w-full bg-binah-purple/30 rounded-t-sm bar-animate"
          data-height="70"
        >
        </div>
        <div
          class="w-full bg-binah-purple/50 rounded-t-sm bar-animate"
          data-height="60"
        >
        </div>
        <div
          class="w-full bg-binah-purple/80 rounded-t-sm bar-animate glow-purple"
          data-height="85"
        >
        </div>
        <div
          class="w-full bg-binah-cyan rounded-t-sm bar-animate bar-latest shadow-[0_0_15px_rgba(0,209,255,0.5)]"
          data-height="100"
        >
        </div>
      </div>
    </div>

    <!-- Side stats -->
    <div class="flex flex-col gap-3">
      <div
        class="bg-gradient-to-br from-binah-purple/20 to-[#111111] border border-binah-purple/20 rounded-[20px] p-3 text-white flex-1 flex flex-col justify-center"
      >
        <div class="text-xs font-semibold text-white/60 mb-1">Pedidos</div>
        <div class="text-xl font-extrabold">
          <span class="counter" data-target="847">0</span>
        </div>
        <div class="text-[10px] text-binah-cyan font-bold mt-1 badge-pulse">
          +12.5%
        </div>
      </div>
      <div
        class="bg-[#111111] border border-white/5 rounded-[20px] p-3 flex-1 flex flex-col justify-center"
      >
        <div class="text-xs font-semibold text-white/50 mb-1">Envíos</div>
        <div class="text-xl font-extrabold text-white">
          <span class="counter" data-target="384">0</span>
        </div>
        <div class="text-[10px] text-binah-pink font-bold mt-1 badge-pulse">
          +8.3%
        </div>
      </div>
    </div>

    <!-- Bottom row -->
    <div class="col-span-3 grid grid-cols-2 gap-3">
      <div
        class="bg-[#111111] border border-white/5 rounded-[24px] p-4 relative overflow-hidden"
      >
        <div class="text-xs font-semibold text-white/50 mb-1">
          Campaña Activa
        </div>
        <div class="flex items-center gap-2">
          <div class="text-lg font-extrabold text-white">
            <span class="counter" data-target="1203" data-format="dots">0</span>
          </div>
          <div
            class="px-2 py-0.5 bg-binah-cyan/20 border border-binah-cyan/30 rounded-full text-binah-cyan text-[9px] font-bold badge-pulse"
          >
            +15%
          </div>
        </div>
        <!-- Fixed-height chat area -->
        <div class="mt-3 space-y-1.5 h-[46px] overflow-hidden">
          <div
            class="flex items-center justify-start h-[20px]"
            id="chat-slot-0"
          >
            <div
              class="chat-slot-inner text-[9px] px-2.5 py-1 rounded-r-xl rounded-tl-xl max-w-[130px] truncate font-medium bg-[#1A1A1A] border border-white/10 text-white/80"
            >
              ¿Disponible?
            </div>
          </div>
          <div class="flex items-center justify-end h-[20px]" id="chat-slot-1">
            <div
              class="chat-slot-inner text-[9px] px-2.5 py-1 rounded-l-xl rounded-tr-xl max-w-[130px] truncate font-medium bg-gradient-to-r from-binah-purple to-binah-pink text-white shadow-[0_0_10px_rgba(255,46,151,0.3)]"
            >
              Sí, te envío info
            </div>
          </div>
        </div>
      </div>

      <div
        class="bg-[#111111] border border-white/5 rounded-[24px] p-4 flex flex-col justify-between"
      >
        <div class="text-xs font-semibold text-white/50 mb-1">Inventario</div>
        <div class="flex items-center justify-between">
          <div class="text-lg font-extrabold text-white">
            <span class="counter" data-target="2456" data-format="dots">0</span>
          </div>
          <div class="flex items-end gap-[3px] inventory-bars h-8">
            <div
              class="w-1.5 bg-white/20 rounded-full bar-animate"
              data-height-px="16"
            >
            </div>
            <div
              class="w-1.5 bg-white/30 rounded-full bar-animate"
              data-height-px="24"
            >
            </div>
            <div
              class="w-1.5 bg-binah-purple/60 rounded-full bar-animate"
              data-height-px="12"
            >
            </div>
            <div
              class="w-1.5 bg-binah-cyan rounded-full bar-animate shadow-[0_0_8px_rgba(0,209,255,0.6)]"
              data-height-px="28"
            >
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Live activity feed -->
    <div class="col-span-3 mt-2">
      <div class="flex items-center gap-1.5 mb-2.5 px-1">
        <div
          class="w-1.5 h-1.5 rounded-full bg-binah-pink shadow-[0_0_5px_rgba(255,46,151,0.8)] live-dot"
        >
        </div>
        <span
          class="text-[9px] font-bold text-white/40 uppercase tracking-widest"
          >Actividad Reciente</span
        >
      </div>
      <div class="space-y-2">
        <div
          class="activity-slot flex items-center gap-2.5 bg-white/5 border border-white/5 rounded-xl px-3 py-1.5 h-8 overflow-hidden backdrop-blur-sm"
          id="activity-slot-0"
        >
          <span class="slot-icon text-xs w-5 text-center shrink-0 opacity-80"
            >🛍️</span
          >
          <span
            class="slot-text text-[10px] font-medium text-white/80 flex-1 truncate"
            >Nuevo pedido #1284</span
          >
          <span
            class="slot-tag text-[8px] font-bold text-white/90 px-2 py-0.5 rounded-full bg-binah-purple border border-binah-purple/50 whitespace-nowrap"
            >Pedido</span
          >
        </div>
        <div
          class="activity-slot flex items-center gap-2.5 bg-white/5 border border-white/5 rounded-xl px-3 py-1.5 h-8 overflow-hidden backdrop-blur-sm"
          id="activity-slot-1"
        >
          <span class="slot-icon text-xs w-5 text-center shrink-0 opacity-80"
            >💬</span
          >
          <span
            class="slot-text text-[10px] font-medium text-white/80 flex-1 truncate"
            >María: "¿Tienen talla M?"</span
          >
          <span
            class="slot-tag text-[8px] font-bold text-white/90 px-2 py-0.5 rounded-full bg-[#25d366]/40 border border-[#25d366]/50 whitespace-nowrap"
            >WhatsApp</span
          >
        </div>
        <div
          class="activity-slot flex items-center gap-2.5 bg-white/5 border border-white/5 rounded-xl px-3 py-1.5 h-8 overflow-hidden backdrop-blur-sm"
          id="activity-slot-2"
        >
          <span class="slot-icon text-xs w-5 text-center shrink-0 opacity-80"
            >✨</span
          >
          <span
            class="slot-text text-[10px] font-medium text-white/80 flex-1 truncate"
            >Bot respondió automáticamente</span
          >
          <span
            class="slot-tag text-[8px] font-bold text-white/90 px-2 py-0.5 rounded-full bg-white/10 border border-white/20 whitespace-nowrap text-center"
            >IA</span
          >
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Live indicator pulse */
  .live-dot {
    animation: live-pulse 2s ease-in-out infinite;
  }

  @keyframes live-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }

  /* Badge pulse */
  .badge-pulse {
    animation: badge-glow 3s ease-in-out infinite;
  }

  @keyframes badge-glow {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.6;
    }
  }

  /* Bar chart animation */
  .bar-animate {
    height: 0%;
    transition: height 1s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .mockup-root.animated .bar-animate {
    height: var(--bar-height);
  }

  /* Inventory bars use px */
  .inventory-bars .bar-animate {
    height: 0px;
  }

  .mockup-root.animated .inventory-bars .bar-animate {
    height: var(--bar-height-px);
  }

  /* Latest bar subtle pulse */
  .bar-latest {
    animation: bar-pulse 2.5s ease-in-out infinite;
    animation-delay: 2s;
  }

  @keyframes bar-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.7;
    }
  }

  /* Crossfade for activity slots and chat slots */
  .activity-slot .slot-icon,
  .activity-slot .slot-text,
  .activity-slot .slot-tag,
  .chat-slot-inner {
    transition: opacity 0.4s ease;
  }

  .activity-slot.crossfade .slot-icon,
  .activity-slot.crossfade .slot-text,
  .activity-slot.crossfade .slot-tag,
  .chat-slot-inner.crossfade {
    opacity: 0;
  }
</style>

<script>
  function initDashboard() {
    const mockup = document.getElementById("dashboard-mockup");
    if (!mockup) return;

    let started = false;

    // --- Number counter animation ---
    function animateCounter(el: HTMLElement) {
      const target = parseInt(el.dataset.target || "0");
      const format = el.dataset.format || "plain";
      const duration = 1500;
      const start = performance.now();

      function update(now: number) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.round(eased * target);

        if (format === "currency" || format === "dots") {
          el.textContent = current.toLocaleString("es-CL");
        } else {
          el.textContent = current.toString();
        }

        if (progress < 1) {
          requestAnimationFrame(update);
        }
      }
      requestAnimationFrame(update);
    }

    // --- Bar chart animation ---
    function animateBars() {
      const bars = mockup!.querySelectorAll<HTMLElement>(".bar-animate");
      bars.forEach((bar, i) => {
        const heightPct = bar.dataset.height;
        const heightPx = bar.dataset.heightPx;
        if (heightPct) bar.style.setProperty("--bar-height", heightPct + "%");
        if (heightPx) bar.style.setProperty("--bar-height-px", heightPx + "px");
        bar.style.transitionDelay = `${i * 80}ms`;
      });
      mockup!.classList.add("animated");
    }

    // --- Activity feed: crossfade content in fixed slots ---
    const activities = [
      {
        icon: "🛒",
        text: "Nuevo pedido #1284",
        tag: "Pedido",
        tagColor: "bg-binah-purple",
      },
      {
        icon: "💬",
        text: 'María: "¿Tienen talla M?"',
        tag: "WhatsApp",
        tagColor: "bg-[#25d366]",
      },
      {
        icon: "🤖",
        text: "Bot respondió automáticamente",
        tag: "IA",
        tagColor: "bg-binah-charcoal",
      },
      {
        icon: "📦",
        text: "Envío #892 entregado",
        tag: "Envío",
        tagColor: "bg-blue-500",
      },
      {
        icon: "💬",
        text: 'Carlos: "Quiero 3 unidades"',
        tag: "WhatsApp",
        tagColor: "bg-[#25d366]",
      },
      {
        icon: "🧾",
        text: "Factura #F-2847 generada",
        tag: "Factura",
        tagColor: "bg-amber-500",
      },
      {
        icon: "🛒",
        text: "Nuevo pedido #1285",
        tag: "Pedido",
        tagColor: "bg-binah-purple",
      },
      {
        icon: "🤖",
        text: "Recordatorio enviado a 12 clientes",
        tag: "Auto",
        tagColor: "bg-binah-charcoal",
      },
      {
        icon: "📦",
        text: "Envío #893 despachado",
        tag: "Envío",
        tagColor: "bg-blue-500",
      },
      {
        icon: "💬",
        text: 'Ana: "¿Cuánto cuesta el envío?"',
        tag: "WhatsApp",
        tagColor: "bg-[#25d366]",
      },
      {
        icon: "🤖",
        text: "Bot: cotización enviada a Ana",
        tag: "IA",
        tagColor: "bg-binah-charcoal",
      },
      {
        icon: "🛒",
        text: "Nuevo pedido #1286",
        tag: "Pedido",
        tagColor: "bg-binah-purple",
      },
    ];

    // Track which activity index each slot currently shows
    const slotActivityIndex = [0, 1, 2];
    let nextActivityIndex = 3;
    let nextSlotToUpdate = 0;

    const tagColorMap: Record<string, string> = {
      Pedido: "bg-binah-purple",
      WhatsApp: "bg-[#25d366]",
      IA: "bg-binah-charcoal",
      Auto: "bg-binah-charcoal",
      Envío: "bg-blue-500",
      Factura: "bg-amber-500",
    };

    function updateActivitySlot() {
      const slotId = `activity-slot-${nextSlotToUpdate}`;
      const slot = document.getElementById(slotId);
      if (!slot) return;

      const a = activities[nextActivityIndex % activities.length];
      nextActivityIndex++;
      nextSlotToUpdate = (nextSlotToUpdate + 1) % 3;

      // Crossfade out
      slot.classList.add("crossfade");

      setTimeout(() => {
        // Update content while hidden
        const icon = slot.querySelector(".slot-icon");
        const text = slot.querySelector(".slot-text");
        const tag = slot.querySelector(".slot-tag") as HTMLElement;
        if (icon) icon.textContent = a.icon;
        if (text) text.textContent = a.text;
        if (tag) {
          tag.textContent = a.tag;
          // Update tag color
          Object.values(tagColorMap).forEach((c) => tag.classList.remove(c));
          tag.classList.add(tagColorMap[a.tag] || "bg-binah-purple");
        }

        // Crossfade in
        slot.classList.remove("crossfade");
      }, 400);
    }

    // --- Counter bump: periodically nudge numbers up ---
    const counterEls = mockup.querySelectorAll<HTMLElement>(".counter");
    function bumpCounters() {
      counterEls.forEach((el) => {
        const currentText = el.textContent || "0";
        const current = parseInt(
          currentText.replace(/\./g, "").replace(/,/g, "")
        );
        const bump =
          el.dataset.format === "currency"
            ? Math.floor(Math.random() * 50000) + 10000
            : Math.floor(Math.random() * 3) + 1;
        const newVal = current + bump;
        const format = el.dataset.format || "plain";

        if (format === "currency" || format === "dots") {
          el.textContent = newVal.toLocaleString("es-CL");
        } else {
          el.textContent = newVal.toString();
        }
      });
    }

    // --- Orchestrate everything with IntersectionObserver ---
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !started) {
            started = true;

            // 1. Animate bars
            animateBars();

            // 2. Animate counters
            setTimeout(() => {
              counterEls.forEach((el) => animateCounter(el));
            }, 300);

            // 4. Ongoing loops — crossfade in place, no layout shifts
            setInterval(() => updateActivitySlot(), 3500);
            setInterval(() => bumpCounters(), 6000);
          }
        });
      },
      { threshold: 0.3 }
    );

    observer.observe(mockup);
  }

  document.addEventListener("DOMContentLoaded", initDashboard);
  document.addEventListener("astro:page-load", initDashboard);
</script>

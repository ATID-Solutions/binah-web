---
const features = [
  {
    id: 'gestion-pedidos',
    title: 'Gestión de Pedidos',
    description:
      'Recibe pedidos de <strong class="text-binah-purple">Shopify</strong> y <strong class="text-binah-purple">WooCommerce</strong> automáticamente. Gestiona estados, pagos, canales de venta y notas desde un solo panel.',
    detail:
      'Centraliza todos tus canales de venta en una única interfaz. Filtra por estado, transportadora o fecha. Asigna pedidos a bodegas y genera envíos con un clic.',
    url: 'app.binah.co/pedidos',
  },
  {
    id: 'whatsapp-ia',
    title: 'WhatsApp con IA',
    description:
      'Chatbot inteligente que atiende clientes, detecta pedidos y escala a tu equipo. <strong class="text-binah-purple">Campañas masivas</strong>, plantillas y gestión multicanal.',
    detail:
      'El chatbot responde consultas frecuentes, confirma estados de pedido y escala automáticamente a un agente humano cuando detecta intención de compra.',
    url: 'app.binah.co/whatsapp',
  },
  {
    id: 'envios-integrados',
    title: 'Envíos Integrados',
    description:
      'Genera guías de <strong class="text-binah-purple">Coordinadora</strong> y <strong class="text-binah-purple">99 Envíos</strong> con un clic. Cotiza, imprime rótulos y rastrea paquetes en tiempo real.',
    detail:
      'Compara tarifas entre transportadoras, genera guías masivas y envía notificaciones automáticas de tracking a tus clientes por WhatsApp.',
    url: 'app.binah.co/envios',
  },
  {
    id: 'facturacion-siigo',
    title: 'Facturación con Siigo',
    description:
      'Genera facturas y comprobantes de pago en <strong class="text-binah-purple">Siigo</strong> automáticamente al despachar un pedido.',
    detail:
      'Facturación electrónica <strong class="text-binah-purple">DIAN</strong> con ruteo inteligente según bodega de despacho o medio de pago.',
    url: 'app.binah.co/facturas',
  },
  {
    id: 'inventario',
    title: 'Inventario Multi-bodega',
    description:
      'Control de stock en <strong class="text-binah-purple">tiempo real</strong> entre múltiples bodegas. Alertas de bajo inventario, transferencias y sincronización con tu tienda.',
    detail:
      'Gestiona stock en múltiples ubicaciones, configura alertas de reposición y sincroniza automáticamente con Shopify y WooCommerce.',
    url: 'app.binah.co/inventario',
  },
  {
    id: 'automatizaciones',
    title: 'Automatizaciones',
    description:
      'Flujos automáticos que conectan pedidos, envíos, facturación y mensajes de <strong class="text-binah-purple">WhatsApp</strong>. Dispara acciones por webhooks o cambios de estado.',
    detail:
      'Crea flujos personalizados que se ejecutan automáticamente. Conecta cualquier acción con <strong class="text-binah-purple">webhooks</strong> entrantes y salientes.',
    url: 'app.binah.co/automatizaciones',
  },
];

const navItems = features.map((f) => ({ id: f.id, label: f.title }));
---

<section id="funcionalidades" class="bg-black border-y border-white/5 py-24 lg:py-32 relative">
  <!-- Soft glows for background -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
    <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-binah-purple opacity-10 blur-[150px] rounded-full"></div>
    <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-binah-cyan opacity-5 blur-[120px] rounded-full"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-20 lg:mb-28">
      <h2 class="text-4xl lg:text-6xl font-extrabold tracking-tighter text-white">
        Todo lo que necesitas para <span class="text-transparent bg-clip-text bg-gradient-to-r from-binah-cyan via-binah-purple to-binah-pink">vender más</span>
      </h2>
      <p class="mt-6 text-lg lg:text-xl font-medium text-slate-400 max-w-2xl mx-auto leading-relaxed">
        Funcionalidades integradas que trabajan juntas para potenciar tu operación de e-commerce.
      </p>
    </div>

    <div class="grid lg:grid-cols-[280px_1fr] gap-12 lg:gap-16">
      <!-- Sticky sidebar -->
      <div class="hidden lg:block">
        <nav class="sticky top-32 space-y-1">
          {navItems.map((item) => (
            <a
              href={`#${item.id}`}
              data-feature-nav
              class="feature-nav-link flex items-center gap-4 px-5 py-3.5 rounded-2xl border border-transparent transition-all duration-300 text-slate-500 font-semibold text-sm hover:text-white hover:bg-white/5 group"
            >
              <span class="w-1.5 h-1.5 rounded-full bg-slate-700 transition-all duration-300 group-hover:bg-binah-cyan feature-nav-dot"></span>
              {item.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Feature content -->
      <div class="space-y-20 lg:space-y-32">
        {features.map((feature, i) => (
          <div
            id={feature.id}
            data-feature-section
            class={`flex flex-col gap-8 md:gap-12 ${i % 2 !== 0 ? 'md:flex-row-reverse' : 'md:flex-row'} items-center`}
          >
            <!-- Text -->
            <div class="flex-1 w-full">
              <h3 class="text-3xl lg:text-4xl font-extrabold tracking-tight mb-5 text-white">
                {feature.title}
              </h3>
              <p class="text-slate-300 font-medium leading-relaxed mb-4 text-lg" set:html={feature.description.replace(/text-binah-purple/g, 'text-binah-cyan')} />
              <p class="text-slate-500 font-medium leading-relaxed text-base" set:html={feature.detail.replace(/text-binah-purple/g, 'text-white')} />
            </div>

            <!-- Visual: Dashboard mockup -->
            <div class="flex-1 w-full rounded-[32px] overflow-hidden border border-white/10 shadow-bento bg-[#0A0A0A] relative group">
              <div class="absolute inset-0 bg-gradient-to-br from-binah-purple/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
              
              <!-- Browser chrome -->
              <div class="bg-black/80 backdrop-blur-md h-10 px-4 flex items-center gap-2 border-b border-white/5 relative z-10">
                <div class="flex gap-1.5">
                  <div class="w-3 h-3 rounded-full bg-[#ff5f57]/80"></div>
                  <div class="w-3 h-3 rounded-full bg-[#febc2e]/80"></div>
                  <div class="w-3 h-3 rounded-full bg-[#28c840]/80"></div>
                </div>
                <div class="flex-1 flex justify-center">
                  <div class="bg-white/5 border border-white/10 rounded-md px-4 py-1 text-white/40 text-[10px] sm:text-xs font-medium tracking-wide">
                    {feature.url}
                  </div>
                </div>
                <div class="w-[52px]"></div>
              </div>

              <!-- ============ ORDERS MOCKUP ============ -->
              {feature.id === 'gestion-pedidos' && (
                <div class="p-4 bg-transparent relative z-10">
                  <div class="flex gap-2 mb-4 flex-wrap">
                    <span class="bg-binah-purple text-white text-[10px] font-bold px-3 py-1.5 rounded-full shadow-[0_0_10px_rgba(77,55,246,0.5)]">Todos (847)</span>
                    <span class="bg-white/5 text-white/50 text-[10px] font-medium px-3 py-1.5 rounded-full border border-white/10 hover:bg-white/10 transition-colors">Pendientes</span>
                    <span class="bg-white/5 text-white/50 text-[10px] font-medium px-3 py-1.5 rounded-full border border-white/10 hover:bg-white/10 transition-colors">En proceso</span>
                    <span class="bg-white/5 text-white/50 text-[10px] font-medium px-3 py-1.5 rounded-full border border-white/10 hover:bg-white/10 transition-colors">Entregados</span>
                  </div>
                  <div class="bg-[#111111] rounded-[20px] border border-white/10 overflow-hidden">
                    <table class="w-full text-xs">
                      <thead>
                        <tr class="border-b border-white/5 bg-white/5">
                          <th class="text-left py-3 px-4 text-white/40 font-semibold tracking-wide">Pedido</th>
                          <th class="text-left py-3 px-4 text-white/40 font-semibold tracking-wide hidden sm:table-cell">Cliente</th>
                          <th class="text-left py-3 px-4 text-white/40 font-semibold tracking-wide">Total</th>
                          <th class="text-left py-3 px-4 text-white/40 font-semibold tracking-wide hidden sm:table-cell">Canal</th>
                          <th class="text-right py-3 px-4 text-white/40 font-semibold tracking-wide">Estado</th>
                        </tr>
                      </thead>
                      <tbody>
                        {[
                          { id: '#1847', client: 'María García', total: '$245,000', channel: 'Shopify', channelColor: 'bg-[#ff2e97]/10 text-[#ff2e97] border border-[#ff2e97]/20', status: 'Entregado', statusColor: 'bg-[#00d1ff]/10 text-[#00d1ff] border border-[#00d1ff]/20' },
                          { id: '#1846', client: 'Carlos López', total: '$180,500', channel: 'Woo', channelColor: 'bg-white/10 text-white/80 border border-white/20', status: 'En proceso', statusColor: 'bg-binah-purple/20 text-binah-purple border border-binah-purple/30' },
                          { id: '#1845', client: 'Ana Rodríguez', total: '$92,000', channel: 'Shopify', channelColor: 'bg-[#ff2e97]/10 text-[#ff2e97] border border-[#ff2e97]/20', status: 'Pendiente', statusColor: 'bg-amber-500/10 text-amber-500 border border-amber-500/20' },
                          { id: '#1844', client: 'José Martínez', total: '$310,200', channel: 'Woo', channelColor: 'bg-white/10 text-white/80 border border-white/20', status: 'Entregado', statusColor: 'bg-[#00d1ff]/10 text-[#00d1ff] border border-[#00d1ff]/20' },
                          { id: '#1843', client: 'Laura Torres', total: '$156,800', channel: 'Shopify', channelColor: 'bg-[#ff2e97]/10 text-[#ff2e97] border border-[#ff2e97]/20', status: 'En proceso', statusColor: 'bg-binah-purple/20 text-binah-purple border border-binah-purple/30' },
                        ].map((order) => (
                          <tr class="border-b border-white/5 last:border-0 hover:bg-white/[0.02] transition-colors">
                            <td class="py-3 px-4 font-extrabold text-white">{order.id}</td>
                            <td class="py-3 px-4 text-slate-400 hidden sm:table-cell">{order.client}</td>
                            <td class="py-3 px-4 text-slate-300 font-bold">{order.total}</td>
                            <td class="py-3 px-4 hidden sm:table-cell">
                              <span class={`inline-block text-[9px] font-bold px-2 py-0.5 rounded-full ${order.channelColor}`}>{order.channel}</span>
                            </td>
                            <td class="py-3 px-4 text-right">
                              <span class={`inline-block text-[9px] font-bold px-2 py-0.5 rounded-full ${order.statusColor}`}>{order.status}</span>
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              )}

              <!-- ============ WHATSAPP MOCKUP ============ -->
              {feature.id === 'whatsapp-ia' && (
                <div class="h-full flex flex-col relative z-10">
                  <div class="bg-black/40 backdrop-blur-md px-4 py-3 flex items-center gap-3 border-b border-white/5">
                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-binah-cyan/20 to-binah-purple/20 flex items-center justify-center shrink-0 border border-white/10 shadow-[0_0_10px_rgba(0,209,255,0.2)]">
                      <span class="text-white text-xs font-bold">MG</span>
                    </div>
                    <div class="min-w-0">
                      <div class="text-white text-xs font-bold">María García</div>
                      <div class="text-white/40 text-[10px]">+57 311 456 7890</div>
                    </div>
                    <div class="ml-auto shrink-0">
                      <span class="bg-binah-cyan/10 text-binah-cyan text-[9px] font-bold px-2 py-1 rounded-full flex items-center gap-1.5 border border-binah-cyan/20">
                        <span class="w-1.5 h-1.5 rounded-full bg-binah-cyan animate-pulse shadow-[0_0_5px_rgba(0,209,255,0.8)]"></span>
                        IA Activa
                      </span>
                    </div>
                  </div>
                  <div class="bg-black/20 p-4 space-y-3 flex-1 flex flex-col justify-end">
                    <div class="flex justify-end">
                      <div class="bg-[#1A1A1A] rounded-xl rounded-tr-sm px-3 py-2 max-w-[85%] border border-white/10 shadow-sm relative group overflow-hidden">
                        <p class="text-[11px] text-white/80 leading-relaxed font-medium">Hola, quiero saber el estado de mi pedido #1847</p>
                        <span class="text-[9px] text-white/40 float-right mt-1 ml-3">10:42 AM</span>
                      </div>
                    </div>
                    <div class="flex justify-start">
                      <div class="bg-gradient-to-br from-[#111111] to-[#1A1A1A] rounded-xl rounded-tl-sm px-3 py-2 max-w-[90%] border border-white/10 shadow-[0_4px_20px_rgba(0,0,0,0.5)] relative overflow-hidden">
                        <!-- Subtle glow on the AI message -->
                        <div class="absolute inset-0 bg-gradient-to-r from-binah-purple/5 to-binah-cyan/5 pointer-events-none"></div>
                        <div class="flex items-center gap-1.5 mb-1 relative z-10">
                          <span class="bg-gradient-to-r from-binah-purple to-binah-cyan text-white text-[8px] font-bold px-1.5 py-0.5 rounded shadow-[0_0_8px_rgba(77,55,246,0.4)]">IA</span>
                          <span class="text-[9px] text-white/50 font-medium">Binah Bot</span>
                        </div>
                        <p class="text-[11px] text-white/90 leading-relaxed relative z-10">¡Hola María! Tu pedido <strong class="text-white">#1847</strong> fue despachado con <strong class="text-white">Coordinadora</strong>. Guía: CR-789456. Llegada estimada: mañana entre 2-5pm.</p>
                        <span class="text-[9px] text-white/40 float-right mt-1 ml-3 relative z-10">10:42 AM</span>
                      </div>
                    </div>
                    <div class="flex justify-end">
                       <div class="bg-[#1A1A1A] rounded-xl rounded-tr-sm px-3 py-2 max-w-[85%] border border-white/10 shadow-sm relative group overflow-hidden">
                        <p class="text-[11px] text-white/80 leading-relaxed font-medium">Perfecto, gracias!</p>
                        <span class="text-[9px] text-white/40 float-right mt-1 ml-3">10:43 AM</span>
                      </div>
                    </div>
                    <div class="flex justify-start">
                      <div class="bg-gradient-to-br from-[#111111] to-[#1A1A1A] rounded-xl rounded-tl-sm px-3 py-2 max-w-[90%] border border-white/10 shadow-[0_4px_20px_rgba(0,0,0,0.5)] relative overflow-hidden">
                        <div class="absolute inset-0 bg-gradient-to-r from-binah-purple/5 to-binah-cyan/5 pointer-events-none"></div>
                        <div class="flex items-center gap-1.5 mb-1 relative z-10">
                          <span class="bg-gradient-to-r from-binah-purple to-binah-cyan text-white text-[8px] font-bold px-1.5 py-0.5 rounded shadow-[0_0_8px_rgba(77,55,246,0.4)]">IA</span>
                        </div>
                        <p class="text-[11px] text-white/90 leading-relaxed relative z-10">¡Con gusto! ¿Necesitas algo más? Estoy aquí para ayudarte.</p>
                        <span class="text-[9px] text-white/40 float-right mt-1 ml-3 relative z-10">10:43 AM</span>
                      </div>
                    </div>
                  </div>
                </div>
              )}

              <!-- ============ SHIPPING MOCKUP ============ -->
              {feature.id === 'envios-integrados' && (
                <div class="p-4 bg-transparent relative z-10 space-y-4">
                  <div class="text-[11px] text-white/50 font-bold tracking-wide uppercase">Cotización · Pedido #1847 · BOG → MDE</div>
                  <div class="grid grid-cols-2 gap-3">
                    <div class="bg-[#111111] rounded-2xl p-4 border border-white/5 transition-colors hover:bg-white/5">
                      <div class="flex items-center gap-2 mb-3">
                        <div class="w-6 h-6 rounded border border-white/10 flex items-center justify-center bg-white/5">
                          <span class="text-white/80 text-[9px] font-bold">CO</span>
                        </div>
                        <span class="font-bold text-[12px] text-white">Coordinadora</span>
                      </div>
                      <div class="text-xl font-extrabold text-white">$12,500</div>
                      <div class="text-[10px] text-slate-400 mt-1 font-medium">2-3 días hábiles</div>
                    </div>
                    <div class="bg-gradient-to-br from-binah-purple/20 to-[#111111] rounded-2xl p-4 border border-binah-purple/30 relative">
                      <span class="absolute -top-2 right-3 bg-gradient-to-r from-binah-cyan to-binah-purple text-white text-[8px] font-bold px-2 py-0.5 rounded-full shadow-[0_0_10px_rgba(77,55,246,0.5)]">Mejor precio</span>
                      <div class="flex items-center gap-2 mb-3">
                        <div class="w-6 h-6 rounded border border-white/10 flex items-center justify-center bg-white/5">
                          <span class="text-white text-[9px] font-bold">99</span>
                        </div>
                        <span class="font-bold text-[12px] text-white">Múltiples Transportadoras</span>
                      </div>
                      <div class="text-xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-binah-cyan to-binah-purple">$9,800</div>
                      <div class="text-[10px] text-slate-400 mt-1 font-medium">3-5 días hábiles</div>
                    </div>
                  </div>
                  <div class="bg-[#111111] rounded-[20px] p-4 border border-white/10 relative overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/5 to-transparent skew-x-12 translate-x-[-150%] animate-[shimmer_3s_infinite]"></div>
                    <div class="text-[11px] text-white/50 font-bold mb-5 tracking-wide uppercase">Tracking · Guía CR-789456</div>
                    <div class="flex items-center px-2">
                      <div class="flex flex-col items-center gap-2">
                        <div class="w-6 h-6 rounded-full bg-binah-purple flex items-center justify-center shadow-[0_0_15px_rgba(77,55,246,0.6)] z-10 relative">
                          <div class="absolute inset-0 rounded-full border border-white/30 mix-blend-overlay"></div>
                          <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                        </div>
                        <span class="text-[8px] font-bold text-binah-purple tracking-widest uppercase">Recogido</span>
                      </div>
                      <div class="flex-1 h-0.5 bg-binah-purple opacity-50 mx-1"></div>
                      <div class="flex flex-col items-center gap-2">
                        <div class="w-6 h-6 rounded-full bg-binah-cyan flex items-center justify-center shadow-[0_0_15px_rgba(0,209,255,0.6)] z-10 relative">
                          <div class="absolute inset-0 rounded-full border border-white/30 mix-blend-overlay"></div>
                          <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                        </div>
                        <span class="text-[8px] font-bold text-binah-cyan tracking-widest uppercase">En tránsito</span>
                      </div>
                      <div class="flex-1 h-0.5 bg-white/10 mx-1"></div>
                      <div class="flex flex-col items-center gap-2">
                        <div class="w-6 h-6 rounded-full bg-black border border-white/20 z-10 relative"></div>
                        <span class="text-[8px] font-medium text-slate-500 tracking-widest uppercase">En destino</span>
                      </div>
                      <div class="flex-1 h-0.5 bg-white/10 mx-1"></div>
                      <div class="flex flex-col items-center gap-2">
                        <div class="w-6 h-6 rounded-full bg-black border border-white/20 z-10 relative"></div>
                        <span class="text-[8px] font-medium text-slate-500 tracking-widest uppercase">Entregado</span>
                      </div>
                    </div>
                  </div>
                </div>
              )}

              <!-- ============ INVOICING MOCKUP ============ -->
              {feature.id === 'facturacion-electronica' && (
                <div class="h-full bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-binah-cyan/10 via-transparent to-transparent flex items-center justify-center p-8 relative z-10">
                  <div class="bg-[#111111] w-full max-w-[280px] rounded-2xl shadow-[0_10px_40px_rgba(0,0,0,0.8)] border border-white/10 relative overflow-hidden group-hover:-translate-y-2 transition-transform duration-500">
                    <div class="bg-gradient-to-r from-binah-cyan to-binah-purple h-2 w-full"></div>
                    <div class="p-6">
                      <div class="flex justify-between items-start mb-6">
                        <div>
                          <div class="text-[10px] text-slate-400 font-bold tracking-widest uppercase mb-1">Factura Electrónica</div>
                          <div class="text-white font-extrabold text-xl">#FE-8924</div>
                        </div>
                        <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center">
                          <svg class="w-5 h-5 text-binah-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                      </div>
                      
                      <div class="space-y-4 mb-6">
                        <div class="flex justify-between text-sm">
                          <span class="text-slate-400">Cliente</span>
                          <span class="text-white font-medium">María García</span>
                        </div>
                        <div class="flex justify-between text-sm">
                          <span class="text-slate-400">NIT/CC</span>
                          <span class="text-white font-medium">1020304050</span>
                        </div>
                        <div class="flex justify-between text-sm">
                          <span class="text-slate-400">Fecha</span>
                          <span class="text-white font-medium">24 Oct, 2023</span>
                        </div>
                      </div>
                      
                      <div class="border-t border-white/10 border-dashed pt-4 mb-4">
                        <div class="flex justify-between text-sm font-bold">
                          <span class="text-white">Total a pagar</span>
                          <span class="text-transparent bg-clip-text bg-gradient-to-r from-binah-cyan to-binah-purple font-extrabold text-lg">$245,000</span>
                        </div>
                      </div>

                      <div class="bg-binah-cyan/10 text-binah-cyan text-[10px] font-bold py-2 rounded-lg text-center border border-binah-cyan/20">
                        Enviada a la DIAN con éxito
                      </div>
                    </div>
                  </div>
                </div>
              )}

              <!-- ============ INVENTORY MOCKUP ============ -->
              {feature.id === 'inventario' && (
                <div class="p-3 bg-binah-lavender/40">
                  <div class="bg-white rounded-brutal border-2 border-black overflow-hidden">
                    <table class="w-full text-[10px]">
                      <thead>
                        <tr class="border-b-2 border-black bg-binah-lavender/60">
                          <th class="text-left py-2 px-3 text-black/50 font-bold">Producto</th>
                          <th class="text-center py-2 px-3 text-black/50 font-bold">Principal</th>
                          <th class="text-center py-2 px-3 text-black/50 font-bold hidden sm:table-cell">Norte</th>

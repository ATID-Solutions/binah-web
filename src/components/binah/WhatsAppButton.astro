---
// Floating WhatsApp button + interactive chat bubble.
import { waUrl, WA_MESSAGES } from "./whatsapp";

const options = [
  { label: "Agendar una demo", url: waUrl(WA_MESSAGES.demo), icon: "calendar" },
  { label: "Hablar de precios y planes", url: waUrl(WA_MESSAGES.pricingBusiness), icon: "doc" },
  { label: "Otra consulta", url: waUrl(WA_MESSAGES.general), icon: "chat" },
];
---

<!-- WhatsApp Button + Interactive Chat Bubble -->
<div
  id="wa-container"
  class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-3"
  transition:persist="binah-whatsapp"
>
  <!-- Chat Bubble (hidden initially) -->
  <div id="wa-bubble" class="wa-bubble-hidden pointer-events-none">
    <div class="wa-card">
      <!-- Header bar -->
      <div class="flex items-center gap-2.5 px-4 py-3 wa-header">
        <div class="relative">
          <div class="w-10 h-10 rounded-full bg-white/15 flex items-center justify-center backdrop-blur-sm">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
            </svg>
          </div>
          <span class="absolute -bottom-0.5 -right-0.5 w-3 h-3 bg-[#25d366] rounded-full border-2 border-[#075e54] wa-online-pulse"></span>
        </div>
        <div class="flex-1 min-w-0">
          <p class="!text-white !text-[13.5px] !font-semibold !leading-tight !m-0 truncate">Equipo Binah</p>
          <p class="!text-white/60 !text-[11px] !leading-tight !m-0 !mt-0.5">En línea · Responde en minutos</p>
        </div>
        <button
          id="wa-close"
          class="w-7 h-7 flex items-center justify-center rounded-full hover:bg-white/15 transition-colors cursor-pointer bg-transparent border-none"
          aria-label="Cerrar"
        >
          <svg class="w-4 h-4 text-white/60 hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Chat body -->
      <div class="px-4 py-3.5 wa-chat-body">
        <!-- Typing indicator -->
        <div id="wa-typing" class="flex items-end gap-1.5">
          <div class="wa-msg-bubble inline-flex items-center gap-[5px] px-4 py-3">
            <span class="wa-dot"></span>
            <span class="wa-dot wa-dot-2"></span>
            <span class="wa-dot wa-dot-3"></span>
          </div>
        </div>

        <!-- Actual message -->
        <div id="wa-message" class="wa-message-hidden">
          <div class="wa-msg-bubble px-3.5 py-2.5 relative">
            <div class="wa-msg-tail"></div>
            <p class="!text-[#1a1a1a] !text-[13.5px] !leading-[1.5] !m-0 !font-normal">
              ¡Hola! 👋 Te mostramos cómo Binah puede correr tu negocio en una sola plataforma. ¿Por dónde empezamos?
            </p>
            <div class="flex items-center justify-end gap-1 mt-1">
              <p class="!text-[#8696a0] !text-[10.5px] !leading-none !m-0 !font-normal">Ahora</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick-action options -->
      <div id="wa-options" class="wa-options-hidden">
        {options.map((opt, i) => (
          <a
            href={opt.url}
            target="_blank"
            rel="noopener noreferrer"
            class="wa-option group"
            data-index={i}
          >
            <span class="wa-option-icon">
              {opt.icon === "calendar" && (
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
                </svg>
              )}
              {opt.icon === "doc" && (
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                </svg>
              )}
              {opt.icon === "chat" && (
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z"/>
                </svg>
              )}
            </span>
            <span class="flex-1 text-[13px] text-[#1a1a1a] font-medium">{opt.label}</span>
            <svg class="w-4 h-4 text-[#25d366] opacity-0 -translate-x-1 transition-all duration-200 group-hover:opacity-100 group-hover:translate-x-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- WhatsApp FAB -->
  <button id="wa-fab" aria-label="WhatsApp" class="wa-fab group">
    <!-- Ripple rings -->
    <span class="wa-ripple"></span>
    <span class="wa-ripple wa-ripple-2"></span>

    <!-- Button surface -->
    <span class="wa-fab-surface group-hover:scale-105 group-active:scale-95">
      <svg class="w-[30px] h-[30px] text-white" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>

      <!-- Notification badge -->
      <span id="wa-badge" class="wa-badge-hidden">1</span>
    </span>
  </button>
</div>

<style>
  /* ================================================
     FAB BUTTON
     ================================================ */
  .wa-fab {
    position: relative;
    display: block;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .wa-fab-surface {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: linear-gradient(135deg, #25d366 0%, #128c7e 100%);
    box-shadow:
      0 4px 14px rgba(37, 211, 102, 0.4),
      0 2px 6px rgba(0, 0, 0, 0.1),
      inset 0 1px 1px rgba(255, 255, 255, 0.2);
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.25s ease;
  }

  .wa-fab:hover .wa-fab-surface {
    box-shadow:
      0 6px 20px rgba(37, 211, 102, 0.5),
      0 4px 10px rgba(0, 0, 0, 0.12),
      inset 0 1px 1px rgba(255, 255, 255, 0.2);
  }

  /* Ripple rings */
  .wa-ripple {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    z-index: 5;
    background: rgba(37, 211, 102, 0.15);
    animation: wa-ripple-out 3s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  .wa-ripple-2 { animation-delay: 1s; }

  @keyframes wa-ripple-out {
    0% { transform: scale(1); opacity: 1; }
    100% { transform: scale(2.2); opacity: 0; }
  }

  /* Badge */
  .wa-badge-hidden { display: none; }

  .wa-badge-visible {
    position: absolute;
    top: -3px;
    right: -3px;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    background: #ef4444;
    color: white;
    font-family: 'Geist', 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 700;
    border-radius: 50%;
    border: 2.5px solid white;
    box-shadow: 0 2px 6px rgba(239, 68, 68, 0.4);
    animation: wa-badge-pop 0.45s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  }

  @keyframes wa-badge-pop {
    0% { transform: scale(0); }
    70% { transform: scale(1.2); }
    100% { transform: scale(1); }
  }


  /* ================================================
     CHAT BUBBLE CARD
     ================================================ */
  .wa-card {
    width: 300px;
    border-radius: 10px;
    overflow: hidden;
    background: white;
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.12),
      0 4px 12px rgba(0, 0, 0, 0.06);
  }

  .wa-header {
    background: linear-gradient(135deg, #075e54 0%, #064e46 100%);
  }

  .wa-online-pulse {
    animation: wa-pulse-glow 2s ease-in-out infinite;
  }

  @keyframes wa-pulse-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.5); }
    50% { box-shadow: 0 0 0 4px rgba(37, 211, 102, 0); }
  }

  .wa-chat-body {
    background: #efeae2;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23d1ccc3' fill-opacity='0.25'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    min-height: 70px;
  }

  .wa-msg-bubble {
    background: white;
    border-radius: 8px;
    border-bottom-left-radius: 3px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
  }

  .wa-msg-tail {
    position: absolute;
    left: -6px;
    bottom: 0;
    width: 12px;
    height: 12px;
    background: white;
    clip-path: polygon(100% 0, 100% 100%, 0 100%);
  }


  /* ================================================
     QUICK-ACTION OPTIONS
     ================================================ */
  .wa-options-hidden { display: none; }

  .wa-options-visible {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 10px 12px 12px;
    background: #f0f2f5;
    border-top: 1px solid #e0e0e0;
  }

  .wa-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    background: white;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.15s ease;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    opacity: 0;
    transform: translateY(6px);
  }

  .wa-option-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
    color: #128c7e;
    flex-shrink: 0;
  }

  .wa-option:hover {
    background: #f5f5f5;
    transform: translateX(2px);
  }

  .wa-option-animate {
    animation: wa-option-in 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes wa-option-in {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }


  /* ================================================
     TYPING DOTS
     ================================================ */
  .wa-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #a0aab0;
    animation: wa-bounce 1.3s ease-in-out infinite;
  }

  .wa-dot-2 { animation-delay: 0.15s; }
  .wa-dot-3 { animation-delay: 0.3s; }

  @keyframes wa-bounce {
    0%, 60%, 100% { transform: translateY(0);    opacity: 0.35; }
    30%           { transform: translateY(-5px); opacity: 1;    }
  }


  /* ================================================
     BUBBLE SHOW / HIDE
     ================================================ */
  .wa-bubble-hidden {
    opacity: 0;
    transform: translateY(16px) scale(0.88);
    transform-origin: bottom right;
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .wa-bubble-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    transform-origin: bottom right;
    pointer-events: auto;
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Message reveal */
  .wa-message-hidden { display: none; }

  .wa-message-visible {
    display: block;
    animation: wa-msg-in 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes wa-msg-in {
    from { opacity: 0; transform: translateY(8px) scale(0.94); }
    to   { opacity: 1; transform: translateY(0)   scale(1);    }
  }
</style>

<script>
  (() => {
    const bubble = document.getElementById('wa-bubble');
    const typing = document.getElementById('wa-typing');
    const message = document.getElementById('wa-message');
    const options = document.getElementById('wa-options');
    const badge = document.getElementById('wa-badge');
    const closeBtn = document.getElementById('wa-close');
    const fab = document.getElementById('wa-fab');

    if (!bubble || !typing || !message || !options || !badge || !closeBtn || !fab) return;

    const WA_DISMISSED_KEY = 'binah-wa-dismissed';
    const WA_DISMISSED_DURATION = 24 * 60 * 60 * 1000; // 24 hours

    let bubbleShown = false;
    let dismissed = false;
    let autoShowTimer: ReturnType<typeof setTimeout> | null = null;

    function recentlyDismissed() {
      const at = localStorage.getItem(WA_DISMISSED_KEY);
      return !!at && Date.now() - parseInt(at) < WA_DISMISSED_DURATION;
    }

    // Auto-show after 10 seconds — but only if the user hasn't dismissed recently.
    // Clicking the FAB still opens the bubble regardless of this flag.
    if (!recentlyDismissed()) {
      autoShowTimer = setTimeout(() => {
        if (dismissed) return;
        showBubble();
      }, 10000);
    }

    function showBubble() {
      if (bubbleShown) return;
      bubbleShown = true;
      dismissed = false;

      typing.style.display = '';
      message.classList.remove('wa-message-visible');
      message.classList.add('wa-message-hidden');
      options.classList.remove('wa-options-visible');
      options.classList.add('wa-options-hidden');
      options.querySelectorAll('.wa-option').forEach((el) => {
        el.classList.remove('wa-option-animate');
      });

      bubble.classList.remove('wa-bubble-hidden', 'pointer-events-none');
      bubble.classList.add('wa-bubble-visible');

      badge.classList.remove('wa-badge-hidden');
      badge.classList.add('wa-badge-visible');

      setTimeout(() => {
        if (dismissed) return;
        typing.style.display = 'none';
        message.classList.remove('wa-message-hidden');
        message.classList.add('wa-message-visible');

        setTimeout(() => {
          if (dismissed) return;
          options.classList.remove('wa-options-hidden');
          options.classList.add('wa-options-visible');

          const optionEls = options.querySelectorAll('.wa-option');
          optionEls.forEach((el, i) => {
            setTimeout(() => {
              el.classList.add('wa-option-animate');
            }, i * 100);
          });
        }, 400);
      }, 2000);
    }

    function dismissBubble(persist = true) {
      dismissed = true;
      bubbleShown = false;
      if (autoShowTimer !== null) clearTimeout(autoShowTimer);
      bubble.classList.remove('wa-bubble-visible');
      bubble.classList.add('wa-bubble-hidden', 'pointer-events-none');
      badge.classList.remove('wa-badge-visible');
      badge.classList.add('wa-badge-hidden');
      if (persist) {
        localStorage.setItem(WA_DISMISSED_KEY, Date.now().toString());
      }
    }

    closeBtn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      dismissBubble();
    });

    fab.addEventListener('click', () => {
      if (bubbleShown) {
        // Closing via the FAB is a transient action — don't silence the widget for 24h.
        dismissBubble(false);
      } else {
        showBubble();
      }
    });

    // Clicking a quick-action hides the bubble without writing the long dismissal,
    // since the user is actively engaging.
    options.querySelectorAll('.wa-option').forEach((el) => {
      el.addEventListener('click', () => {
        dismissBubble(false);
      });
    });
  })();
</script>

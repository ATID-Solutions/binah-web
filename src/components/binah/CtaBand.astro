---
import { waUrl, WA_MESSAGES } from "./whatsapp";

interface Props {
  eyebrow?: string;
  heading: string;
  body?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  id?: string;
}

const {
  eyebrow = "Empieza hoy",
  heading,
  body,
  primaryLabel = "Agendar demo",
  primaryHref = waUrl(WA_MESSAGES.demo),
  secondaryLabel,
  secondaryHref,
  id,
} = Astro.props;

// Open external WhatsApp/mailto/tel in a new tab; keep internal links in-page.
const isExternal = /^(https?:|mailto:|tel:)/i.test(primaryHref);
const isSecondaryExternal =
  !!secondaryHref && /^(https?:|mailto:|tel:)/i.test(secondaryHref);
---

<div class="cta-band" id={id}>
  <div>
    <div class="eyebrow" style="margin-bottom: 24px;">{eyebrow}</div>
    <h2 set:html={heading} />
  </div>
  <div class="cta-actions">
    {body && <p style="color: #8a8a85; font-size: 15px; max-width: 36ch; margin-bottom: 8px;">{body}</p>}
    <a
      href={primaryHref}
      class="btn btn-primary"
      target={isExternal ? "_blank" : undefined}
      rel={isExternal ? "noopener noreferrer" : undefined}
    >
      {primaryLabel} <span class="arrow">→</span>
    </a>
    {
      secondaryLabel && secondaryHref && (
        <a
          href={secondaryHref}
          class="btn btn-ghost"
          target={isSecondaryExternal ? "_blank" : undefined}
          rel={isSecondaryExternal ? "noopener noreferrer" : undefined}
        >
          {secondaryLabel}
        </a>
      )
    }
  </div>
</div>

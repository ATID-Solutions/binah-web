---
import { waUrl, WA_MESSAGES } from "./whatsapp";
import { FEATURED_SOLUTIONS } from "../../lib/marketing-pages";

const waContactHref = waUrl(WA_MESSAGES.general);
---

<footer class="binah-footer" transition:persist="binah-footer">
  <div class="container-binah">
    <div class="footer-grid">
      <div class="footer-brand">
        <img class="logo-light" src="/wordmark-black.png" alt="Binah" style="height:28px" />
        <img class="logo-dark" src="/wordmark-white.png" alt="Binah" style="height:28px; display:none" />
        <p>El sistema operativo de los negocios colombianos. Nueve módulos. Una plataforma.</p>
      </div>
      <div class="footer-col">
        <h4>Producto</h4>
        <ul>
          <li><a href="/modulos">Módulos</a></li>
          <li><a href="/modulo-crm">CRM</a></li>
          <li><a href="/modulo-retail">Retail</a></li>
          <li><a href="/precios">Precios</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Compañía</h4>
        <ul>
          <li><a href="/nosotros">Nosotros</a></li>
          <li><a href="#">Clientes</a></li>
          <li><a href="#">Empleos</a></li>
          <li><a href="#">Prensa</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Soluciones</h4>
        <ul>
          {
            FEATURED_SOLUTIONS.map((page) => (
              <li><a href={page.path}>{page.title.replace(" — Binah", "")}</a></li>
            ))
          }
        </ul>
      </div>
      <div class="footer-col">
        <h4>Contacto</h4>
        <ul>
          <li><a href="mailto:hola@binah.co">hola@binah.co</a></li>
          <li><a href={waContactHref} target="_blank" rel="noopener noreferrer">WhatsApp</a></li>
          <li>Barranquilla, Colombia</li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 BINAH S.A.S.</span>
      <span>HECHO EN COLOMBIA ◆ V.2026.04</span>
    </div>
  </div>
</footer>

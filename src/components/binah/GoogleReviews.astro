---
import reviewsCache from "../../data/google-reviews-cache.json";

interface GoogleReview {
  authorName: string;
  authorUri: string;
  authorPhotoUri: string | null;
  rating: number;
  relativePublishTimeDescription: string;
  text: string;
  googleMapsUri: string;
}

interface GoogleReviewsCache {
  placeName: string;
  googleMapsUri: string;
  rating: number | null;
  userRatingCount: number;
  reviews: GoogleReview[];
}

const cache = reviewsCache as GoogleReviewsCache;
const reviews = cache.reviews.filter((review) => review.text.trim().length > 0);
const reviewCountLabel = `${cache.userRatingCount} ${
  cache.userRatingCount === 1 ? "reseña" : "reseñas"
}`;
const ratingLabel =
  cache.rating === null ? reviewCountLabel : `${cache.rating.toFixed(1)} • ${reviewCountLabel}`;
const mapsHref = cache.googleMapsUri || "https://maps.google.com/?cid=17703495939762672124";

function getInitials(name: string) {
  return name
    .split(" ")
    .map((part) => part[0])
    .join("")
    .slice(0, 2)
    .toUpperCase();
}
---

<section class="binah-section google-reviews-section">
  <div class="section-num">
    <span class="n">03</span><span>Google Reviews</span><span class="rule"></span><span>Perfil público</span>
  </div>

  <div class="google-reviews-layout">
    <div class="google-reviews-copy">
      <div class="eyebrow">Reseñas verificadas</div>
      <h2 class="display display-md">
        Lo que dicen de Binah en Google.
      </h2>
      <p>
        Opiniones públicas de clientes que ya usan Binah para centralizar ventas, operación y administración.
      </p>

      <a href={mapsHref} target="_blank" rel="noopener noreferrer" class="google-rating-pill">
        <svg viewBox="0 0 24 24" class="google-g-icon" aria-hidden="true">
          <path
            d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"
            fill="#4285F4"></path>
          <path
            d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
            fill="#34A853"></path>
          <path
            d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
            fill="#FBBC05"></path>
          <path
            d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
            fill="#EA4335"></path>
        </svg>
        <span class="google-rating-stars" aria-label={`${cache.rating ?? 0} de 5 estrellas`}>
          {
            Array.from({ length: 5 }).map(() => (
              <svg viewBox="0 0 20 20" class="google-review-star" aria-hidden="true">
                <path d="m10 1.6 2.58 5.23 5.78.84-4.18 4.08.99 5.75L10 14.79 4.83 17.5l.99-5.75-4.18-4.08 5.78-.84L10 1.6Z"></path>
              </svg>
            ))
          }
        </span>
        <span>{ratingLabel}</span>
      </a>
    </div>

    <div class:list={["google-review-grid", reviews.length === 1 && "single"]}>
      {
        reviews.map((review) => (
          <article class="google-review-card">
            <div class="google-review-source">
              <svg viewBox="0 0 24 24" class="google-g-icon" aria-hidden="true">
                <path
                  d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"
                  fill="#4285F4"></path>
                <path
                  d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                  fill="#34A853"></path>
                <path
                  d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                  fill="#FBBC05"></path>
                <path
                  d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                  fill="#EA4335"></path>
              </svg>
              <span>Google</span>
            </div>

            <div class="google-review-head">
              {review.authorPhotoUri ? (
                <img
                  src={review.authorPhotoUri}
                  alt={review.authorName}
                  loading="lazy"
                  referrerpolicy="no-referrer"
                  class="google-review-avatar"
                />
              ) : (
                <div class="google-review-avatar google-review-avatar-fallback">
                  {getInitials(review.authorName)}
                </div>
              )}

              <div class="google-review-author">
                <a href={review.authorUri} target="_blank" rel="noopener noreferrer">
                  {review.authorName}
                </a>
                <span>{review.relativePublishTimeDescription}</span>
              </div>

              <div class="google-review-stars" aria-label={`${review.rating} de 5 estrellas`}>
                {Array.from({ length: review.rating }).map(() => (
                  <svg viewBox="0 0 20 20" class="google-review-star" aria-hidden="true">
                    <path d="m10 1.6 2.58 5.23 5.78.84-4.18 4.08.99 5.75L10 14.79 4.83 17.5l.99-5.75-4.18-4.08 5.78-.84L10 1.6Z"></path>
                  </svg>
                ))}
              </div>
            </div>

            <blockquote>{review.text}</blockquote>

            <a
              href={review.googleMapsUri || mapsHref}
              target="_blank"
              rel="noopener noreferrer"
              class="google-review-link"
            >
              Ver en Google <span aria-hidden="true">↗</span>
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>

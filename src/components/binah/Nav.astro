---
import { waUrl, WA_MESSAGES } from "./whatsapp";

const links = [
  { href: "/", label: "Inicio", key: "index" },
  { href: "/modulos", label: "Módulos", key: "modulos" },
  { href: "/precios", label: "Precios", key: "precios" },
  { href: "/nosotros", label: "Nosotros", key: "nosotros" },
] as const;

const demoHref = waUrl(WA_MESSAGES.demo);
const appHref = "https://app.binah.co";
---

<nav class="nav" transition:persist="binah-nav">
  <div class="container-binah nav-inner">
    <a href="/" class="nav-logo" aria-label="Binah">
      <img class="logo-light" src="/wordmark-black.png" alt="Binah" width="75" height="24" />
      <img class="logo-dark" src="/wordmark-white.png" alt="Binah" width="75" height="24" />
    </a>
    <div class="nav-links" data-nav-links>
      <span class="nav-pill" data-nav-pill aria-hidden="true"></span>
      {
        links.map((l) => (
          <a href={l.href} data-key={l.key}>
            {l.label}
          </a>
        ))
      }
    </div>
    <div class="nav-cta">
      <a href={appHref} class="btn btn-ghost">Iniciar sesión</a>
      <a href={demoHref} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
        Agendar demo <span class="arrow">→</span>
      </a>
    </div>
    <button
      class="nav-menu-toggle"
      type="button"
      aria-label="Abrir navegación"
      aria-expanded="false"
      data-menu-toggle
    >
      <span></span>
      <span></span>
    </button>
  </div>
</nav>
<div class="nav-menu" data-menu>
  <div class="nav-menu-panel">
    <div class="nav-menu-top">
      <a href="/" class="nav-logo" aria-label="Binah">
        <img class="logo-light" src="/wordmark-black.png" alt="Binah" width="75" height="24" />
        <img class="logo-dark" src="/wordmark-white.png" alt="Binah" width="75" height="24" />
      </a>
      <button class="nav-menu-close" type="button" aria-label="Cerrar navegación" data-menu-close>&times;</button>
    </div>
    <div class="nav-menu-links">
      {
        links.map((l) => (
          <a href={l.href} data-menu-link>
            {l.label}
          </a>
        ))
      }
    </div>
    <div class="nav-menu-actions">
      <a href={appHref} class="btn btn-outline" data-menu-link>Iniciar sesión</a>
      <a href={demoHref} target="_blank" rel="noopener noreferrer" class="btn btn-primary" data-menu-link>
        Agendar demo <span class="arrow">→</span>
      </a>
    </div>
  </div>
</div>

<script>
  // Slides the active-pill behind whichever nav link matches the current page.
  // Runs on initial load and after each Astro view-transition swap.
  function positionNavPill() {
    const container = document.querySelector<HTMLElement>("[data-nav-links]");
    const pill = container?.querySelector<HTMLElement>("[data-nav-pill]");
    if (!container || !pill) return;

    const page = document.body.dataset.page ?? "";
    const active = container.querySelector<HTMLAnchorElement>(`a[data-key="${page}"]`);

    container.querySelectorAll<HTMLAnchorElement>("a[data-key]").forEach((a) => {
      a.classList.toggle("active", a === active);
    });

    if (!active) {
      pill.style.opacity = "0";
      return;
    }

    pill.style.opacity = "1";
    pill.style.width = `${active.offsetWidth}px`;
    pill.style.height = `${active.offsetHeight}px`;
    pill.style.transform = `translate(${active.offsetLeft}px, ${active.offsetTop}px)`;
  }

  // The first paint may need fonts to settle before measurements are accurate.
  function init() {
    positionNavPill();
    if (document.fonts?.ready) document.fonts.ready.then(positionNavPill);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init, { once: true });
  } else {
    init();
  }

  document.addEventListener("astro:after-swap", positionNavPill);
  window.addEventListener("resize", positionNavPill);

  function initMenu() {
    const menu = document.querySelector<HTMLElement>("[data-menu]");
    const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
    const close = document.querySelector<HTMLButtonElement>("[data-menu-close]");
    const links = document.querySelectorAll<HTMLElement>("[data-menu-link]");
    if (!menu || !toggle || !close) return;
    if (menu.dataset.menuReady === "true") return;
    menu.dataset.menuReady = "true";

    const setOpen = (open: boolean) => {
      menu.classList.toggle("open", open);
      toggle.setAttribute("aria-expanded", String(open));
      document.body.classList.toggle("nav-menu-open", open);
    };

    toggle.addEventListener("click", () => setOpen(!menu.classList.contains("open")));
    close.addEventListener("click", () => setOpen(false));
    menu.addEventListener("click", (event) => {
      if (event.target === menu) setOpen(false);
    });
    links.forEach((link) => link.addEventListener("click", () => setOpen(false)));
    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape") setOpen(false);
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initMenu, { once: true });
  } else {
    initMenu();
  }

  document.addEventListener("astro:after-swap", initMenu);
</script>

---
interface Props {
  variant?: "primary" | "secondary" | "white" | "outline-white";
  size?: "sm" | "md" | "lg";
  href?: string;
  class?: string;
}

const {
  variant = "primary",
  size = "md",
  href,
  class: className,
} = Astro.props;

const baseClasses =
  "inline-flex items-center justify-center font-semibold rounded-full transition-all duration-300 cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white overflow-hidden relative group";

const sizeClasses = {
  sm: "px-6 py-2 text-sm",
  md: "px-8 py-3 text-base",
  lg: "px-10 py-4 text-lg",
};

const variantClasses = {
  primary:
    "bg-black text-white hover:scale-105 shadow-xl hover:shadow-2xl hover:bg-slate-900",
  secondary:
    "text-slate-900 bg-white border border-slate-200 hover:border-slate-300 hover:bg-slate-50",
  white: "bg-white text-black shadow-md hover:shadow-lg hover:-translate-y-0.5",
  "outline-white":
    "bg-transparent text-slate-800 border border-slate-300 hover:bg-slate-100 hover:-translate-y-0.5",
};

const classes = [
  baseClasses,
  sizeClasses[size],
  variantClasses[variant],
  className,
]
  .filter(Boolean)
  .join(" ");

const Tag = href ? "a" : "button";
---

<Tag href={href} class={classes}>
  <slot />
</Tag>
